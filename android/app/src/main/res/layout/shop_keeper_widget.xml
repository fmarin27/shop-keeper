<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/shop_keeper_widget_bg"
    android:clickable="true"
    android:focusable="true"
    android:padding="10dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/shop_keeper_widget_inner_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingLeft="14dp"
            android:paddingTop="12dp"
            android:paddingRight="14dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widgetBrand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shop_keeper_widget_brand_bg"
                    android:fontFamily="sans-serif-black"
                    android:paddingLeft="10dp"
                    android:paddingTop="4dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="4dp"
                    android:text="SHOP FLOOR"
                    android:textAllCaps="true"
                    android:textColor="#F8FBFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widgetState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="LIVE"
                    android:textAllCaps="true"
                    android:textColor="#7DD3FC"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/widgetCount"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/shop_keeper_widget_count_bg"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-black"
                android:text="Shop Keeper"
                android:textColor="#F8FBFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetAccent"
                android:layout_width="44dp"
                android:layout_height="4dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/shop_keeper_widget_accent_line"
                android:text="" />

            <TextView
                android:id="@+id/widgetFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tap to open"
                android:textAllCaps="true"
                android:textColor="#7C93AE"
                android:textSize="8sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-black"
                android:text="All Clear"
                android:textAllCaps="true"
                android:textColor="#F8FBFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetSubLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="Shop updates"
                android:textColor="#BFD3EA"
                android:textSize="10sp" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
